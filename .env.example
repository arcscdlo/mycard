# Copie para a Vercel (Settings -> Environment Variables). NAO comitar valores reais.

# --- Stripe (gateway) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Supabase (banco de vendas) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- TikTok (pixel + CAPI) ---
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=

# --- Meta / Facebook (pixel + CAPI) ---
# JSON com 1+ pixels: [{"id":"PIXEL_ID","token":"EAA..."}]
FB_PIXELS=

# --- Relatorio de vendas ---
VENDAS_TOKEN=
